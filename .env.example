# Supabase — obtenha em: https://supabase.com/dashboard/project/<seu-projeto>/settings/api
#
# NEXT_PUBLIC_ = exposto ao navegador (seguro para chaves públicas do Supabase)
# A segurança real vem do Row Level Security (RLS) configurado no Supabase.
#
# NUNCA adicione aqui a service_role_key — ela bypassa o RLS e
# nunca deve ser usada no frontend nem commitada no repositório.

NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<sua-anon-key-publica>
